{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@lms/types/*": [
        "packages/types/src/*"
      ],
      "@lms/config/*": [
        "packages/config/src/*"
      ],
      "@lms/utils/*": [
        "packages/utils/src/*"
      ],
      "@lms/api-client/*": [
        "packages/api-client/src/*"
      ],
      "@lms/ui/*": [
        "packages/ui/src/*"
      ]
    }
  }
}