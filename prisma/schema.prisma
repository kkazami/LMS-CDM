generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Institute {
  id        String   @id @default(cuid())
  code      String   @unique
  name      String
  createdAt DateTime @default(now())

  users           User[]
  courses         Course[]
  notes           Note[]
  taskItems       TaskItem[]
  calendarEvents  CalendarEvent[]
}

model User {
  id          String    @id @default(cuid())
  name        String
  email       String    @unique
  password    String
  role        String    @default("STUDENT") // Roles: "STUDENT", "PROFESSOR", "ADMIN"
  instituteId String
  createdAt   DateTime  @default(now())

  institute   Institute @relation(fields: [instituteId], references: [id])
  sessions    Session[]
  notes       Note[]
  taskItems   TaskItem[]
  calendarEvents CalendarEvent[]
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Course {
  id          String    @id @default(cuid())
  code        String
  title       String
  instituteId String
  createdAt   DateTime  @default(now())

  institute   Institute @relation(fields: [instituteId], references: [id])
  taskItems   TaskItem[]
  calendarEvents CalendarEvent[]
}

model Note {
  id          String    @id @default(cuid())
  title       String    @default("")
  content     String    @default("")
  category    String    @default("General")
  color       String    @default("#ffffff")
  pinned      Boolean   @default(false)
  archived    Boolean   @default(false)
  orderIndex  Int       @default(0)
  creatorId   String
  instituteId String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  creator     User      @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  institute   Institute @relation(fields: [instituteId], references: [id], onDelete: Cascade)

  @@index([instituteId, creatorId])
  @@index([instituteId, archived, pinned, orderIndex])
}

model TaskItem {
  id          String    @id @default(cuid())
  title       String
  description String    @default("")
  priority    String    @default("medium")
  dueDate     DateTime?
  courseId    String?
  completed   Boolean   @default(false)
  archived    Boolean   @default(false)
  orderIndex  Int       @default(0)
  creatorId   String
  instituteId String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  creator     User      @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  institute   Institute @relation(fields: [instituteId], references: [id], onDelete: Cascade)
  course      Course?   @relation(fields: [courseId], references: [id], onDelete: SetNull)

  @@index([instituteId, creatorId])
  @@index([instituteId, completed, orderIndex])
}

model CalendarEvent {
  id            String    @id @default(cuid())
  title         String
  description   String    @default("")
  professorName String    @default("")
  maxPoints     Int?
  eventDate     DateTime
  eventType     String    @default("assignment")
  deepLink      String    @default("#")
  courseId      String?
  creatorId     String
  instituteId   String
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  creator       User      @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  institute     Institute @relation(fields: [instituteId], references: [id], onDelete: Cascade)
  course        Course?   @relation(fields: [courseId], references: [id], onDelete: SetNull)

  @@index([instituteId, eventDate])
  @@index([instituteId, creatorId])
}